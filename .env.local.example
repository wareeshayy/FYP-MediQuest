# Required for authentication, database, quizzes, analytics, and messaging
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =============================================================================
# AI providers — quiz generation & chatbot
# =============================================================================

# Groq (fast fallback) — https://console.groq.com/
GROQ_API_KEY=your_groq_api_key

# Hugging Face — ONE token for ALL models — https://huggingface.co/settings/tokens
# There is NO "MedCama AI" on HF. Use MedGemma for USMLE MCQs.
HUGGINGFACE_API_KEY=hf_your_huggingface_token
HF_API_TOKEN=hf_your_huggingface_token

# Which provider to use: groq | medgemma | biogpt
MEDICAL_AI_PROVIDER=medgemma

# Hugging Face model endpoints (model-name based API)
HF_MODEL_MEDGEMMA=google/medgemma-4b-it
HF_MODEL_BIOGPT=microsoft/biogpt
HF_MODEL_PUBMEDBERT=microsoft/BiomedNLP-PubMedBERT-base-uncased-abstract-fulltext
HF_INFERENCE_BASE_URL=https://router.huggingface.co/hf-inference/models

# Optional alternates
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — Zoom meeting features only
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# Optional — Google OAuth (also configure in Supabase Auth > Google)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
